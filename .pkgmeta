package-as: SimpleTradeSkillExporter

move-folders:
    SimpleTradeSkillExporter/SimpleTradeSkillExporter: SimpleTradeSkillExporter

manual-changelog:
    filename: CHANGELOG.md
    markup-type: markdown

ignore:
    - .github
    - .vscode
    - .luacheckrc
    - .luarc.json
    - .editorconfig
    - .stylua.toml
    - .gitignore
    - README.md
    - CHANGELOG.md
    - LICENSE
    - tests/